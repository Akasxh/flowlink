# FlowLink environment template.
# Copy to .env.local for local dev. Never commit filled-in values.

# ── Database ──────────────────────────────────────────────────────────
# Local dev: SQLite (works out of the box).
# The path is relative to prisma/schema.prisma — so this file lands at prisma/dev.db.
DATABASE_URL="file:./dev.db"
# Production: PostgreSQL (Supabase, Neon, etc.)
# DATABASE_URL="postgresql://user:pass@host:5432/flowlink?schema=public"

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Agent auth (SIWE + JWT signing) ───────────────────────────────────
# Ed25519 private key for signing agent JWTs (hex, 32 bytes = 64 hex chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SIGNING_KEY_HEX="00000000000000000000000000000000000000000000000000000000DEADBEEF"

# ── Receipt signing (ed25519) ─────────────────────────────────────────
# Separate key — receipts outlive JWTs.
RECEIPT_SIGNING_KEY_HEX="00000000000000000000000000000000000000000000000000000000CAFEBABE"

# ── HashKey Chain ─────────────────────────────────────────────────────
NEXT_PUBLIC_HASHKEY_TESTNET_RPC="https://hashkeychain-testnet.alt.technology"
NEXT_PUBLIC_HASHKEY_TESTNET_CHAIN_ID="133"

# ── HashKey Settlement Protocol (optional — app degrades gracefully) ──
# Obtain at: https://merchant.hsp.hashkey.com
HSP_APP_KEY=""
HSP_APP_SECRET=""
HSP_BASE_URL="https://api-testnet.hsp.hashkey.com"
HSP_WEBHOOK_SECRET=""

# ── Rate limiting (optional — falls back to in-memory for dev) ────────
# Required for multi-instance production deploys.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Compliance ────────────────────────────────────────────────────────
# Fail-closed: if this URL is unreachable, pay calls are blocked.
OFAC_API_URL="https://api.ofac.dev/v1/ethereum"
COMPLIANCE_MIN_SCORE="60"
