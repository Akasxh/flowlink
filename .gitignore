# Node / Next.js
node_modules/
.next/
out/
*.tsbuildinfo
.eslintcache

# pnpm / npm / yarn
.npm
.pnpm-store/
.yarn/*
!.yarn/patches

# Environment — never commit
.env
.env.*
!.env.example

# Prisma local dev DB (handle both DATABASE_URL resolutions)
prisma/dev.db
prisma/dev.db-journal
prisma/*.db
prisma/*.db-journal
prisma/migrations/dev/
prisma/prisma/


# Logs + diagnostics
logs
*.log
!pitch/*.log
npm-debug.log*
pids
*.pid

# Coverage + test output
coverage/
*.lcov
.nyc_output/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*~

# Deploy artifacts
.vercel/

# Secrets / keys (defense in depth — never commit signing keys)
*.pem
*.key
*.crt
!public/.well-known/*.pem
# Next.js App Router dir names can legitimately end in .pem (dynamic route serving PEM)
!src/app/**/*.pem/
!src/app/**/*.pem/**

